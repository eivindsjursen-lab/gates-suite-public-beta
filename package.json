{
  "name": "gates-suite",
  "version": "0.1.0-alpha.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint packages/*/src/",
    "test": "vitest run",
    "ci:local": "pnpm install --frozen-lockfile --prefer-offline && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm verify-dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify-dist": "node scripts/check-dist.js",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "changeset:version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "msw": "^2.12.10",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ]
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@octokit/rest": "^22.0.1",
    "zod": "^4.3.6"
  }
}
